{
  "name": "06-professional-testing-workflows",
  "version": "1.0.0",
  "description": "Learn Professional Testing Workflows with Jest and Testcontainers",
  "type": "module",
  "scripts": {
    "start:before": "tsx before/index.ts",
    "start:after": "tsx after/index.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "esbuild": "0.28.0"
  }
}
