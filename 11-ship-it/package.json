{
  "name": "11-ship-it",
  "version": "1.0.0",
  "description": "Docker, CI/CD, and Observability",
  "type": "module",
  "scripts": {
    "start:order-service": "tsx after/order-service/index.ts",
    "start:inventory-service": "tsx after/inventory-service/index.ts",
    "build:order": "tsc -p after/order-service/tsconfig.json",
    "build:inventory": "tsc -p after/inventory-service/tsconfig.json",
    "db:push": "drizzle-kit push",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.4",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.21.4",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.9.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
