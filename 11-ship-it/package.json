{
  "name": "11-ship-it",
  "version": "1.0.0",
  "description": "Docker, CI/CD, and Observability",
  "type": "module",
  "scripts": {
    "start:order-service": "tsx after/order-service/index.ts",
    "start:inventory-service": "tsx after/inventory-service/index.ts",
    "build:order": "tsc -p after/order-service/tsconfig.json",
    "build:inventory": "tsc -p after/inventory-service/tsconfig.json",
    "db:push": "drizzle-kit push",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "esbuild": "0.28.0"
  }
}
